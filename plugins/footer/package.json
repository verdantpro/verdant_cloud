{
  "name": "verdant-footer",
  "version": "1.0.0",
  "description": "Footer for verdant. Renders only the configured links — no generator credit.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./components": {
      "import": "./components.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./index.js",
  "sideEffects": false,
  "peerDependencies": {
    "preact": "^10.0.0"
  },
  "quartz": {
    "name": "footer",
    "displayName": "Footer",
    "category": "component",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 50,
    "defaultEnabled": true,
    "defaultOptions": {
      "links": {}
    },
    "components": {
      "Footer": {
        "displayName": "Footer",
        "defaultPosition": "footer",
        "defaultPriority": 50
      }
    },
    "optionSchema": {
      "links": {
        "type": "object"
      }
    }
  }
}
