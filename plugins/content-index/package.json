{
  "name": "verdant-content-index",
  "version": "1.0.0",
  "description": "Vendored @quartz-community/content-index with the RSS feed filtered to actual notes (no folder/tag listings).",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./index.js",
  "sideEffects": false,
  "quartz": {
    "name": "content-index",
    "displayName": "Content Index",
    "category": "emitter",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 50,
    "defaultEnabled": true,
    "defaultOptions": {
      "enableSiteMap": true,
      "enableRSS": true,
      "rssLimit": 10,
      "rssFullHtml": false,
      "rssSlug": "index",
      "includeEmptyFiles": true
    },
    "optionSchema": {
      "enableSiteMap": {
        "type": "boolean"
      },
      "enableRSS": {
        "type": "boolean"
      },
      "rssLimit": {
        "type": "number"
      },
      "rssFullHtml": {
        "type": "boolean"
      },
      "rssSlug": {
        "type": "string"
      },
      "includeEmptyFiles": {
        "type": "boolean"
      }
    }
  }
}
